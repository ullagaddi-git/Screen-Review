{
  "name": "screenshpeak",
  "version": "1.0.0-beta.1",
  "description": "Voice-to-text and AI-powered screen capture for Windows. Local-first, hotkey-driven, free.",
  "main": "out/main/index.js",
  "author": "ScreenSpeak",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:unpack": "electron-vite build && electron-builder --dir",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "node --experimental-strip-types --test test/*.test.mjs",
    "download:whisper": "node scripts/download-whisper-model.js",
    "download:whisper-bin": "node scripts/download-whisper-binary.js",
    "postinstall": "node scripts/download-whisper-model.js && node scripts/download-whisper-binary.js"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "openai": "^6.35.0",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
